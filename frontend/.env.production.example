# Production Environment Variables for Fleek Deployment
# Copy these to your Fleek dashboard under Site Settings → Environment Variables

# ─── Backend API Configuration ───────────────────────────────────────────────
# Replace with your actual deployed backend URL
VITE_API_URL=https://api.polypulse.co.ke
VITE_API_HOST=api.polypulse.co.ke
VITE_WS_URL=wss://api.polypulse.co.ke

# ─── Stellar Network Configuration ───────────────────────────────────────────
# For testnet deployment
VITE_STELLAR_NETWORK=testnet
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# For mainnet deployment (when ready)
# VITE_STELLAR_NETWORK=mainnet
# VITE_HORIZON_URL=https://horizon.stellar.org
# VITE_SOROBAN_RPC_URL=https://soroban-rpc.mainnet.stellar.org

# ─── Smart Contract IDs ──────────────────────────────────────────────────────
# Replace with your deployed contract IDs
VITE_STELLAR_MARKET_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_STELLAR_CHALLENGE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
