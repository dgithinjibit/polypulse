# ─── Rust Backend Core ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-strong-random-jwt-secret-here

PORT=8000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://polypulse:password@localhost:5432/polypulse
POSTGRES_DB=polypulse
POSTGRES_USER=polypulse
POSTGRES_PASSWORD=your-secure-password-here

# ─── Redis / WebSocket ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://polypulse.co.ke,https://www.polypulse.co.ke

# ─── Stellar Network (Backend) ───────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_MARKET_CONTRACT_ID=
STELLAR_CHALLENGE_CONTRACT_ID=
STELLAR_P2P_BET_CONTRACT_ID=

# ─── P2P Betting ──────────────────────────────────────────────────────────────
# Secret key for encrypting/decrypting shareable bet URLs (AES-256-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=your-strong-random-encryption-secret-here

# Stellar treasury address to receive platform fees (2% of winnings)
STELLAR_TREASURY_ADDRESS=

# Stellar admin address for dispute resolution
STELLAR_ADMIN_ADDRESS=
STELLAR_P2P_BET_CONTRACT_ID=

# ─── P2P Betting ──────────────────────────────────────────────────────────────
# Secret key for encrypting/decrypting shareable bet URLs (AES-256-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=your-strong-random-encryption-secret-here

# Stellar treasury address to receive platform fees (2% of winnings)
STELLAR_TREASURY_ADDRESS=

# Stellar admin address for dispute resolution
STELLAR_ADMIN_ADDRESS=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Backend API base URL
VITE_API_URL=http://localhost:8000
VITE_API_HOST=localhost:8000
VITE_WS_URL=ws://localhost:8000

# Stellar Network Configuration
# Network: 'testnet' or 'mainnet'
VITE_STELLAR_NETWORK=testnet
# Horizon API URL (testnet: https://horizon-testnet.stellar.org, mainnet: https://horizon.stellar.org)
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
# Soroban RPC URL (testnet: https://soroban-testnet.stellar.org, mainnet: https://soroban-rpc.mainnet.stellar.org)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Smart Contract IDs (deployed on Stellar)
VITE_STELLAR_MARKET_CONTRACT_ID=
VITE_STELLAR_CHALLENGE_CONTRACT_ID=
VITE_STELLAR_P2P_BET_CONTRACT_ID=
VITE_STELLAR_P2P_BET_CONTRACT_ID=
